{
  "buildCommand": "cd askbetter && npm install && npm run build",
  "outputDirectory": "askbetter/dist",
  "installCommand": "cd askbetter && npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/fetch-share",
      "destination": "/askbetter/api/fetch-share.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
